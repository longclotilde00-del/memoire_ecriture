  urldate = {2026-05-13},
  abstract = {Are we in a cultural crisis? As generative AI and consumption society are in full swing, cultural institutions are reconsidering their ways. How does one ensure the integrity of cultural collections in the virtual era? Those questions are especially relevant for the Institut national de l’audiovisuel, which currently experiences deep changes in its practices and its raisons d’être. In the context of a project mapping documentary processes within the institute, this study returns to Marshall McLuhan’s infamous statement: if the medium is the message, then as far as cultural institutions are concerned, the medium is the memory. This dissertation explores three phases embodying three different epochs in the INA’s documentary history: a first, physical and ideological era that follows the establishment of television as a mass medium; a computerised era that incorporates the televisual document within the new paradigm of the information society; and a digital era in an increasingly virtual society where points of reference must be recreated lest they are lost.},
  keywords = {Audiovisuel,Bases de données,Bibliothèque,Collections patrimoniales,Document audiovisuel,Documentation,Institut national de l'audiovisuel,Institution culturelle,Institution patrimoniale,Intelligence artificielle,Internet,Interopérabilité,Télévision,Web},
